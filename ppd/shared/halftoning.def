// Common halftoning options and translations for all DYMO printers

Option DymoHalftoning/Halftoning PickOne AnySetup 20
DefaultDymoHalftoning ErrorDiffusion
Choice Default/Default "<</cupsColorOrder 0/cupsColorSpace 3/cupsBitsPerColor 1/cupsBitsPerPixel 1>>setpagedevice"
Choice ErrorDiffusion/Error Diffusion "<</cupsColorOrder 0/cupsColorSpace 1/cupsBitsPerColor 8>>setpagedevice"
Choice NLL/Nonlinear Dithering "<</cupsColorOrder 0/cupsColorSpace 1/cupsBitsPerColor 8>>setpagedevice"

LocAttribute "de" Translation "DymoHalftoning" "Halbtöne"
LocAttribute "de" Choice "Default/Standard" ""
LocAttribute "de" Choice "ErrorDiffusion/Fehlerstreuung" ""
LocAttribute "de" Choice "NLL/Nichtlineare Farbmischung" ""
