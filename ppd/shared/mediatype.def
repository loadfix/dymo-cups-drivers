// Common mediatype options and translations for all DYMO printers

Option "MediaType/Label Width" PickOne AnySetup 9
Choice "6mm/6mm" "<</cupsMediaType 0>>setpagedevice"
Choice "9mm/9mm" "<</cupsMediaType 1>>setpagedevice"
Choice "12mm/12mm" "<</cupsMediaType 2>>setpagedevice"
Choice "19mm/19mm" "<</cupsMediaType 3>>setpagedevice"
Choice "24mm/24mm" "<</cupsMediaType 4>>setpagedevice"

