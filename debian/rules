#!/usr/bin/make -f

# Skip `make check`. The upstream test suite uses CPPUNIT_ASSERT_EQUAL
# against types the test headers don't know how to stream (e.g.
# std::vector<unsigned char>), which GCC 15 rejects. Debian's 0010 patch
# works around some of them but not all, and the tests aren't part of the
# installable deb anyway — only the filter binaries and PPDs ship.
%:
	dh $@ --with=pyppd

override_dh_auto_test:
	true
